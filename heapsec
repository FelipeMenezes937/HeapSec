#!/bin/bash
# Simple runner for HeapSec Antivirus

# Compile if needed
if [ ! -d "out/classes" ] || [ src/main/java -nt out/classes ]; then
    echo "Compiling HeapSec Antivirus..."
    mkdir -p out/classes
    javac -d out/classes --source-path src/main/java src/main/java/antivirus/*.java src/main/java/antivirus/*/*.java
    if [ $? -ne 0 ]; then
        echo "Compilation failed!"
        exit 1
    fi
    echo "Compilation successful!"
fi

# Run the antivirus
echo "Starting HeapSec Antivirus..."
java -cp out/classes antivirus.AntivirusScanner "$@"
